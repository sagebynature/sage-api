# =============================================================================
# Sage API Configuration
# All variables use the SAGE_API_ prefix (case-insensitive).
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Required ---
SAGE_API_API_KEY=your-api-key-here

# --- Agent LLM Provider ---
# Required by agent config.toml [env] sections (Azure AI / LiteLLM)
AZURE_AI_API_KEY=
AZURE_AI_API_BASE=

# --- Redis ---
SAGE_API_REDIS_URL=redis://localhost:6379/0

# --- Agents ---
SAGE_API_AGENTS_DIR=./agents

# --- Sessions ---
SAGE_API_SESSION_TTL_SECONDS=1800

# --- Server ---
SAGE_API_HOST=0.0.0.0
SAGE_API_PORT=8000
SAGE_API_REQUEST_TIMEOUT_SECONDS=120

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
SAGE_API_LOG_LEVEL=INFO
